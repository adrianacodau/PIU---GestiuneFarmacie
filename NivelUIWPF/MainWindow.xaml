<Window x:Class="NivelUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Farmacie" Height="720" Width="1000">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <Button Content="Administrare medicamente"
                    Height="38"
                    Margin="0,0,0,8"
                    Click="btnMeniuAdministrare_Click"/>

            <Button Content="Cautare"
                    Height="38"
                    Margin="0,0,0,8"
                    Click="btnMeniuCautare_Click"/>
        </StackPanel>

        <Grid Grid.Column="1">

            <Grid x:Name="panelAdministrare">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Label x:Name="lblNume" Content="Nume"/>
                    <TextBox x:Name="txtNume"
                             Text="{Binding MedicamentCurent.nume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="30"/>

                    <Label x:Name="lblPret" Content="Pret"/>
                    <TextBox x:Name="txtPret"
                             Text="{Binding MedicamentCurent.pret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="30"/>

                    <Label x:Name="lblProducator" Content="Producator"/>
                    <TextBox x:Name="txtProducator"
                             Text="{Binding MedicamentCurent.producator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="30"/>

                    <Label x:Name="lblCategorie" Content="Categorie"/>
                    <ComboBox x:Name="cmbCategorie"
                              SelectedItem="{Binding MedicamentCurent.categorie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Height="30"/>

                    <Label x:Name="lblForma" Content="Forma medicament"/>
                    <ComboBox x:Name="cmbFormaMedicament"
                              SelectedItem="{Binding MedicamentCurent.formaMedicament, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Height="30"/>

                    <Label x:Name="lblDataExpirare" Content="Data expirare"/>
                    <DatePicker x:Name="dtpDataExpirare"
                                SelectedDate="{Binding MedicamentCurent.dataExpirare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Height="30"/>

                    <Label x:Name="lblModAdministrare" Content="Mod administrare"/>
                    <WrapPanel>
                        <CheckBox x:Name="chkOral" Content="Oral" Margin="0,0,15,0"/>
                        <CheckBox x:Name="chkInjectabil" Content="Injectabil" Margin="0,0,15,0"/>
                        <CheckBox x:Name="chkTopic" Content="Topic" Margin="0,0,15,0"/>
                        <CheckBox x:Name="chkInhalator" Content="Inhalator" Margin="0,0,15,0"/>
                    </WrapPanel>

                    <TextBlock x:Name="txtMesajEroare"
                               Foreground="Red"
                               Margin="0,8,0,8"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                    <WrapPanel Margin="0,10,0,0">
                        <Button x:Name="btnAdauga"
                                Content="Create / Adauga"
                                Width="120"
                                Height="32"
                                Margin="0,0,8,0"
                                Click="btnAdauga_Click"/>

                        <Button x:Name="btnActualizeaza"
                                Content="Update"
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="btnActualizeaza_Click"/>

                        <Button x:Name="btnSterge"
                                Content="Delete"
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                IsEnabled="False"
                                Click="btnSterge_Click"/>

                        <Button Content="Reset"
                                Width="100"
                                Height="32"
                                Click="btnReset_Click"/>
                    </WrapPanel>
                </StackPanel>

                <DataGrid x:Name="dgMedicamente"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionChanged="dgMedicamente_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding IdMedicament}" Width="60"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding nume}" Width="130"/>
                        <DataGridTextColumn Header="Pret" Binding="{Binding pret}" Width="90"/>
                        <DataGridTextColumn Header="Producator" Binding="{Binding producator}" Width="130"/>
                        <DataGridTextColumn Header="Categorie" Binding="{Binding categorie}" Width="120"/>
                        <DataGridTextColumn Header="Mod administrare" Binding="{Binding modAdministrare}" Width="140"/>
                        <DataGridTextColumn Header="Forma" Binding="{Binding formaMedicament}" Width="100"/>
                        <DataGridTextColumn Header="Data expirare" Binding="{Binding dataExpirare, StringFormat=dd.MM.yyyy}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid x:Name="panelCautare" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <Label Content="Cauta dupa nume"/>
                    <TextBox x:Name="txtCautareNume" Height="30"/>

                    <WrapPanel Margin="0,8,0,0">
                        <Button Content="Cauta"
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                Click="btnCauta_Click"/>

                        <Button Content="Reset cautare"
                                Width="120"
                                Height="32"
                                Click="btnResetCautare_Click"/>
                    </WrapPanel>
                </StackPanel>

                <TextBox x:Name="txtRezultatCautare"
                         Grid.Row="1"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>

        </Grid>
    </Grid>
</Window>